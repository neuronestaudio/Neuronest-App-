# Neuronest — environment template. Copy to `.env.local` and fill in.
# (.env.local is gitignored, so your endpoint stays private.)

# Where feedback submissions are POSTed (Formspree / Make / Zapier / GHL webhook).
# Get a Formspree URL: https://formspree.io -> New form -> copy the endpoint.
# Leave empty to keep feedback on each visitor's device only (localStorage).
VITE_FEEDBACK_ENDPOINT=
